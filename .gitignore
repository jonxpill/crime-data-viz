# dependencies
node_modules/

# build output
dist/
dist-ssr/
# shareable single-file build (a ~5MB artifact; regenerate with `npm run build:single`)
crime-data-viz-standalone.html

# vite / tooling caches
.vite/
*.local

# logs
*.log
npm-debug.log*

# local machine settings (permission grants — per-machine, not shared)
.claude/settings.local.json

# editor / OS
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
*.swp

# scratch / data work (kept out of the engine repo until baked)
scratchpad/
*.tmp

# Raw data INPUTS. The baked public/data/capetown.json is what ships; these are the
# re-processable sources. The SAPACR crime data is CC-BY (redistributable WITH
# attribution — see README), so its CSV stays tracked for reproducibility; only the
# redundant Stata/SPSS copies and the bulky/derived rasters are omitted:
#  · *.dta / *.sav        → duplicate formats of the tracked SAPACR CSV
#  · data/raw/*.tif       → WorldPop 2020 rasters (URLs in pipeline/clip-worldpop.mjs)
#  · data/raw/sal-pop.csv → Stats SA Census 2011 Small Area Layer (not used yet)
pipeline/sapacr-2008-2023-v1.1/*.dta
pipeline/sapacr-2008-2023-v1.1/*.sav
data/raw/*.tif
data/raw/sal-pop.csv
# AWS Terrain Tiles (z10) — re-downloadable elevation DEM (an inline # is NOT a gitignore comment)
data/raw/terrain/
